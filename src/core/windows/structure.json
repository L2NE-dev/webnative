{
  "security": {
    "disableCors": true,
    "disableCsp": true,
    "disableCspMetaTags": true,
    "disableWebSecurity": true,
    "allowInsecureContent": true,
    "allowFileAccessFromFiles": true,
    "allowFileAccess": true,
    "disableStrictIsolation": true,
    "experimentalPlatformApi": true,
    "ignoreCertificateErrors": true,
    "markOriginsAsSecure": ["http://localhost:3000", "http://192.168.1.100:8080"],
    "allowedHosts": ["localhost", "127.0.0.1"],
    "allowAllHosts": false,
    "disableAutomationFlag": true,
    "disableBackgroundThrottling": true,
    "enableSharedArrayBuffer": true,
    "allowPrivateNetworkRequests": true,
    "allowInsecureLocalhost": true,
    "disableNotifications": true,
    "disableExtensions": true,
    "noSandbox": false,
    "corsAllowOrigin": "*",
    "corsAllowMethods": "GET, POST, PUT, DELETE, PATCH, OPTIONS",
    "corsAllowHeaders": "*",
    "corsAllowCredentials": false,
    "corsMaxAge": "86400",
    "customFlags": ["--flag1=value1", "--flag2"]
  },
  "permissions": {
    "autoAllowAll": true,
    "savesInProfile": true,
    "microphone": "allow",
    "camera": "allow",
    "geolocation": "allow",
    "notifications": "deny",
    "clipboardRead": "allow",
    "multiple": "allow",
    "fileReadWrite": "allow",
    "autoplay": "allow",
    "localFonts": "allow",
    "midiSysex": "allow",
    "windowManagement": "allow",
    "persistentDurableStorage": "allow",
    "idleDetection": "allow",
    "storageAccess": "allow",
    "documentPictureInPicture": "allow"
  },
  "features": {
    "pna": {
      "enabled": true,
      "autoAllowPreflight": true,
      "addPrivateNetworkHeader": true,
      "ignoreWorkerErrors": true,
      "ignoreNavigationErrors": true,
      "disableEnforcement": false
    },
    "autofill": true,
    "experimentalWebPlatformFeatures": true,
    "webGPU": true,
    "webBluetooth": true,
    "webUSB": true,
    "webSerial": true,
    "webHID": true,
    "webNFC": true,
    "webShare": true,
    "webAuthn": true,
    "clipboardWrite": true,
    "fullscreen": true,
    "pictureInPicture": true,
    "virtualReality": true,
    "augmentedReality": true,
    "sensors": true,
    "wakeLock": true,
    "contacts": true,
    "handwriting": true,
    "computePressure": true,
    "smartCard": true,
    "webTransport": true,
    "federatedCredentials": true,
    "digitalGoods": true,
    "paymentRequest": true
  }
}
