{
  "compilerOptions": {
    "target": "esnext",            
    "module": "nodenext",            
    "moduleResolution": "nodenext",    
    "outDir": "lib",               
    "rootDir": "src",              
    "strict": true,                
    "esModuleInterop": true,       
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
		"types": ["node"],
  },
}
